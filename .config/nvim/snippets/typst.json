{
  "corner": {
    "prefix": "corner",
    "body": [
      "#place(",
      "top + right,",
      "text(fill: red, weight: \"bold\", size: 24pt)[Previously shown],",
      ")"
    ],
    "description": "Corner label"
  },
  "twocol": {
    "prefix": "twocol",
    "body": ["#grid(columns: (1fr, 1fr), [", "$1", "],[", "$2", "])"],
    "description": "Two columns with #grid"
  },
  "threecol": {
    "prefix": "threecol",
    "body": [
      "#grid(columns: (1fr, 1fr, 1fr), [",
      "$1",
      "],[",
      "$2",
      "],[",
      "$3",
      "])"
    ],
    "description": "Three columns with #grid"
  }
}
